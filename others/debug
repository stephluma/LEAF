    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;600;700;800&amp;family=Source+Sans+3:wght@400;600;700&amp;display=swap" rel="stylesheet">
    <!-- Material Symbols Outlined — static axes; FILL controlled via CSS only -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,400,0,0">

    <!-- TODO: verify path before production -->
    <link rel="stylesheet" href="/platform/designs/files/launchpad.css">

    <style>
      /* Filled icons — !important beats launchpad.css FILL:0 and any
         leaf_nav.js injected styles regardless of load order */
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 1, 'wght' 400, 'opsz' 24, 'GRAD' 0 !important;
      }

      #header, #footer { display: none !important; }

      /* ── Help Library tokens (mapped to launchpad.css vars) ── */
      .hl-root {
        --hl-navy-deep:   var(--lp-hl);
        --hl-navy-mid:    #1f5796;
        --hl-accent:      var(--lp-accent);
        --hl-accent-strong: var(--lp-hl);
        --hl-accent-weak: var(--c-blue5);
        --hl-border-soft: var(--c-blue10);
        --hl-surface:     #fff;
        --hl-bg:          var(--c-gray5);
        --hl-radius:      var(--r-lg);
        --hl-radius-sm:   var(--r);
        --hl-shadow:      0 2px 12px rgba(0,0,0,.08);
        --hl-muted-label: var(--c-muted);

        --hl-badge-video-bg:   var(--c-blue5);
        --hl-badge-video-text: var(--lp-hl);
        --hl-badge-tut-bg:     #e6f9f2;
        --hl-badge-tut-text:   #0a6e4e;
        --hl-badge-faq-bg:     #fef3e2;
        --hl-badge-faq-text:   #8a5800;
        --hl-badge-new-bg:     #edfce7;
        --hl-badge-new-text:   #267a1e;
        --hl-start-bg:         #fffbeb;
        --hl-start-border:     #f59e0b;
        --hl-start-icon:       #92400e;

        --hl-row-border-video:    var(--lp-hl);
        --hl-row-border-tutorial: #0a6e4e;
        --hl-row-border-faq:      #8a5800;

        min-height: 100vh;
        background: var(--hl-bg);
        font-family: 'Source Sans 3', 'Source Sans Pro', sans-serif;
        color: var(--c-text);
        font-size: 1rem;
      }

      /* ── Skip link ── */
      .hl-skip {
        position: absolute;
        left: 16px;
        top: -80px;
        padding: 8px 14px;
        background: #fff;
        border: 2px solid var(--lp-accent);
        color: var(--lp-accent);
        border-radius: var(--r);
        font-weight: 700;
        font-size: 0.875rem;
        text-decoration: none;
        transition: top 0.15s ease;
        z-index: 3000;
      }
      .hl-skip:focus { top: 16px; outline: 3px solid var(--lp-accent); outline-offset: 2px; }

      /* ── Icon colour overrides ── */
      .hl-root .hl-sbox-btn .material-symbols-outlined { color: #fff !important; }
      .hl-root .hl-cat-strip .material-symbols-outlined { color: var(--c-muted) !important; }
      .hl-root .hl-ctab.on .material-symbols-outlined   { color: var(--lp-accent) !important; }
      .hl-root .hl-sbr .material-symbols-outlined       { color: var(--c-muted) !important; }
      .hl-root .hl-sbr.on .material-symbols-outlined    { color: var(--lp-accent) !important; }
      .hl-root .hl-spill .material-symbols-outlined     { color: var(--c-muted) !important; }
      .hl-root .hl-spill.on .material-symbols-outlined  { color: var(--lp-accent) !important; }
      .hl-root .hl-dbc .material-symbols-outlined       { color: var(--lp-accent) !important; }
      .hl-root .hl-dhero .material-symbols-outlined     { color: var(--lp-accent) !important; }
      .hl-root .hl-dhico .material-symbols-outlined     { color: var(--lp-accent) !important; }
      .hl-root .hl-dact .material-symbols-outlined      { color: var(--c-muted) !important; }
      .hl-root .hl-dact:hover .material-symbols-outlined { color: var(--lp-accent) !important; }
      .hl-root .hl-dmeta-row .material-symbols-outlined  { color: var(--hl-muted-label) !important; }
      .hl-root .hl-empty .material-symbols-outlined      { color: var(--hl-border-soft) !important; }
      .hl-root .hl-fc-ico .material-symbols-outlined,
      .hl-root .hl-lr-ico .material-symbols-outlined,
      .hl-root .hl-drii .material-symbols-outlined       { color: inherit !important; }
      .hl-root .hl-lr-arr,
      .hl-root .hl-drel-arr                              { color: var(--hl-border-soft) !important; }
      .hl-root .hl-pdf-close .material-symbols-outlined  { color: #fff !important; }
      .hl-root .hl-vid-fallback-ico .material-symbols-outlined { color: #fff !important; }
      .hl-root .hl-grp-hdr .material-symbols-outlined   { color: var(--hl-muted-label) !important; }
      .hl-root .hl-sh-ico .material-symbols-outlined    { color: var(--hl-start-icon) !important; }
      .hl-root .hl-show-more .material-symbols-outlined  { color: var(--lp-accent) !important; }

      /* ── Hero ── */
      .hl-hero {
        background: var(--lp-hl);
        padding: 48px 24px;
        text-align: center;
        border-bottom: 1px solid var(--hl-border-soft);
        position: relative;
        overflow: hidden;
      }
      .hl-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 80% 120% at 80% 50%, rgba(0,94,162,0.4), transparent 65%);
        pointer-events: none;
      }
      .hl-hero h1 {
        font-family: 'Public Sans', sans-serif;
        font-size: 1.75rem;
        font-weight: 800;
        color: #fff;
        margin: 0 0 5px;
        position: relative;
        z-index: 1;
      }
      .hl-hero p {
        font-size: 0.95rem;
        color: rgba(255,255,255,0.72);
        margin: 0 0 22px;
        position: relative;
        z-index: 1;
      }
      .hl-sbox {
        display: flex;
        max-width: 500px;
        margin: 0 auto;
        border-radius: var(--hl-radius);
        overflow: hidden;
        border: 1px solid var(--hl-border-soft);
        box-shadow: 0 4px 18px rgba(0,0,0,.28);
        position: relative;
        z-index: 1;
      }
      .hl-sbox input {
        flex: 1;
        border: none;
        padding: 12px 18px;
        font-size: 1rem;
        font-family: inherit;
        color: var(--c-text);
        outline: none;
        background: #fff;
      }
      .hl-sbox input::placeholder { color: #bbb; }
      .hl-sbox input:focus { outline: 3px solid var(--lp-accent); outline-offset: -3px; }
      .hl-sbox-btn {
        background: var(--lp-accent);
        border: none;
        padding: 0 16px;
        cursor: pointer;
        display: flex;
        align-items: center;
      }
      .hl-sbox-btn:focus-visible { outline: 3px solid var(--lp-hl); outline-offset: 2px; }

      /* ── Category strip ── */
      .hl-cat-strip {
        background: #fff;
        border-bottom: 1px solid var(--hl-border-soft);
        display: flex;
        overflow-x: auto;
        padding: 0 24px;
        scrollbar-width: none;
        box-shadow: 0 1px 4px rgba(15,23,42,.06);
      }
      .hl-cat-strip::-webkit-scrollbar { display: none; }
      .hl-ctab {
        display: flex;
        align-items: center;
        gap: 7px;
        padding: 12px 16px;
        font-family: 'Public Sans', sans-serif;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--c-muted);
        border-bottom: 2.5px solid transparent;
        cursor: pointer;
        white-space: nowrap;
        user-select: none;
        background: none;
        border-top: none;
        border-left: none;
        border-right: none;
        transition: color 0.15s;
      }
      .hl-ctab .material-symbols-outlined { font-size: 18px; flex-shrink: 0; }
      .hl-ctab.on { color: var(--lp-accent); border-bottom-color: var(--lp-accent); font-weight: 700; }
      .hl-ctab:hover:not(.on) { color: var(--lp-accent); }
      .hl-ctab:focus-visible { outline: 3px solid var(--lp-accent); outline-offset: -2px; }
      .hl-ctab-n {
        font-size: 0.7rem;
        font-weight: 700;
        background: var(--lp-hl);
        color: #fff;
        border-radius: 10px;
        padding: 1px 7px;
      }
      .hl-ctab.on .hl-ctab-n { background: var(--lp-accent); }
      .hl-ctab.hl-ctab-sh { color: #92400e; }
      .hl-ctab.hl-ctab-sh.on { color: #92400e; border-bottom-color: #92400e; }
      .hl-ctab.hl-ctab-sh .hl-ctab-n,
      .hl-ctab.hl-ctab-sh.on .hl-ctab-n { background: #92400e; }

      /* ── Page layout ── */
      .hl-page-layout {
        display: grid;
        grid-template-columns: 215px 1fr;
        align-items: stretch;
        min-height: calc(100vh - 180px);
      }

      /* ── Sidebar ── */
      .hl-sidebar {
        background: transparent;
        border-right: 1px solid var(--hl-border-soft);
      }
      .hl-sb-sec { padding: 14px 0; border-bottom: 1px solid var(--hl-border-soft); }
      .hl-sb-lbl {
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--hl-muted-label);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 0 16px 8px;
        display: block;
      }
      .hl-sbr {
        display: flex;
        align-items: center;
        gap: 9px;
        padding: 9px 16px;
        font-size: 0.875rem;
        color: var(--c-muted);
        border-left: 3px solid transparent;
        cursor: pointer;
        background: none;
        border-top: none;
        border-right: none;
        border-bottom: none;
        width: 100%;
        text-align: left;
        font-family: inherit;
        transition: background 0.1s;
      }
      .hl-sbr:hover:not(.on) { background: var(--hl-accent-weak); }
      .hl-sbr:focus-visible { outline: 3px solid var(--lp-accent); outline-offset: -2px; }
      .hl-sbr.on {
        color: var(--lp-accent);
        background: var(--hl-accent-weak);
        border-left-color: var(--lp-accent);
        font-weight: 700;
      }
      .hl-sbr-n {
        margin-left: auto;
        font-size: 0.7rem;
        font-weight: 700;
        background: var(--lp-hl);
        color: #fff;
        border-radius: 10px;
        padding: 1px 7px;
      }
      .hl-sbr.on .hl-sbr-n { background: var(--lp-accent); }
      .hl-sb-cta {
        margin: 14px;
        background: var(--hl-accent-weak);
        border: 1px solid var(--c-blue20);
        border-radius: var(--hl-radius-sm);
        padding: 14px;
      }
      .hl-sb-cta p { font-size: 0.8rem; color: var(--c-text); line-height: 1.55; margin: 0 0 10px; }
      .hl-sb-cta a {
        display: block;
        text-align: center;
        background: var(--lp-accent);
        color: #fff !important;
        font-size: 0.8rem;
        font-weight: 700;
        padding: 9px;
        border-radius: var(--hl-radius-sm);
        text-decoration: none;
        transition: filter 0.15s;
      }
      .hl-sb-cta a:hover { filter: brightness(1.08); }
      .hl-sb-cta a:focus-visible { outline: 3px solid var(--lp-accent); outline-offset: 2px; }

      /* ── Main ── */
      .hl-main { padding: 20px 24px; background: var(--hl-bg); }
      .hl-main-hdr {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
        flex-wrap: wrap;
        gap: 8px;
      }
      .hl-count { font-size: 0.875rem; color: var(--c-muted); }
      .hl-count strong { color: var(--c-text); }
      .hl-sort-pills { display: flex; gap: 6px; }
      .hl-spill {
        font-size: 0.8rem;
        padding: 5px 12px;
        border-radius: 20px;
        border: 1px solid var(--hl-border-soft);
        color: var(--c-muted);
        background: var(--hl-surface);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 5px;
        font-family: inherit;
        transition: all 0.12s;
      }
      .hl-spill .material-symbols-outlined { font-size: 16px; }
      .hl-spill.on { background: var(--hl-accent-weak); border-color: var(--lp-accent); color: var(--lp-accent); font-weight: 700; }
      .hl-spill:focus-visible { outline: 3px solid var(--lp-accent); outline-offset: 2px; }
      .hl-sec-lbl {
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--hl-muted-label);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 10px;
        display: block;
      }

      /* ── Start Here band ── */
      .hl-sh-band {
        background: var(--hl-start-bg);
        border: 1px solid var(--hl-start-border);
        border-radius: var(--hl-radius);
        padding: 16px;
        margin-bottom: 20px;
      }
      .hl-sh-hdr { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
      .hl-sh-title { font-size: 0.875rem; font-weight: 700; color: #92400e; text-transform: uppercase; letter-spacing: 0.06em; }
      .hl-sh-desc { font-size: 0.8rem; color: #78350f; margin-left: auto; }

      /* ── Featured grid ── */
      .hl-feat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 8px; }
      .hl-fcard {
        background: var(--hl-surface);
        border: 1px solid var(--hl-border-soft);
        border-radius: var(--hl-radius);
        padding: 16px;
        cursor: pointer;
        transition: border-color 0.15s, box-shadow 0.15s;
        text-align: left;
        font-family: inherit;
        width: 100%;
      }
      .hl-fcard:hover { border-color: var(--lp-accent); box-shadow: var(--hl-shadow); }
      .hl-fcard:focus-visible { outline: 3px solid var(--lp-accent); outline-offset: 2px; }
      .hl-sh-band .hl-fcard { border-color: #fcd34d; }
      .hl-sh-band .hl-fcard:hover { border-color: var(--hl-start-border); box-shadow: 0 4px 12px rgba(245,158,11,.15); }
      .hl-fc-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
      .hl-fc-ico { width: 40px; height: 40px; border-radius: 9px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
      .hl-fc-badges { display: flex; flex-direction: column; gap: 4px; align-items: flex-end; }
      .hl-fc-title { font-size: 0.875rem; font-weight: 700; color: var(--c-text); margin: 0 0 5px; line-height: 1.35; }
      .hl-fc-desc { font-size: 0.8rem; color: var(--c-muted); line-height: 1.5; margin: 0; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }

      /* ── Category groups ── */
      .hl-grp { margin-bottom: 24px; }
      .hl-grp-hdr {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 0;
        margin-bottom: 8px;
        border-bottom: 2px solid var(--hl-border-soft);
        cursor: pointer;
        background: none;
        border-top: none;
        border-left: none;
        border-right: none;
        width: 100%;
        text-align: left;
        font-family: inherit;
      }
      .hl-grp-hdr:focus-visible { outline: 3px solid var(--lp-accent); outline-offset: 2px; }
      .hl-grp-name { font-size: 1rem; font-weight: 700; color: var(--c-text); flex: 1; }
      .hl-grp-count { font-size: 0.7rem; font-weight: 700; background: var(--lp-hl); color: #fff; border-radius: 10px; padding: 2px 8px; }
      .hl-grp-chevron { font-size: 20px; transition: transform 0.2s; }
      .hl-grp.collapsed .hl-grp-chevron { transform: rotate(-90deg); }
      .hl-grp-body { display: flex; flex-direction: column; gap: 7px; }
      .hl-grp.collapsed .hl-grp-body { display: none; }

      /* ── List rows ── */
      .hl-list-rows { display: flex; flex-direction: column; gap: 7px; }
      .hl-lrow {
        display: flex;
        align-items: center;
        gap: 12px;
        background: var(--hl-surface);
        border: 1px solid var(--hl-border-soft);
        border-radius: var(--hl-radius);
        padding: 11px 14px;
        cursor: pointer;
        transition: border-color 0.15s;
        text-align: left;
        font-family: inherit;
        width: 100%;
        border-left-width: 4px;
      }
      .hl-lrow.hl-lrow-video    { border-left-color: var(--hl-row-border-video); }
      .hl-lrow.hl-lrow-tutorial { border-left-color: var(--hl-row-border-tutorial); }
      .hl-lrow.hl-lrow-faq      { border-left-color: var(--hl-row-border-faq); }
      .hl-lrow:hover { border-color: var(--lp-accent); border-left-color: var(--lp-accent); }
      .hl-lrow:focus-visible { outline: 3px solid var(--lp-accent); outline-offset: 2px; }
      .hl-lr-ico { width: 32px; height: 32px; border-radius: 7px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
      .hl-lr-body { flex: 1; min-width: 0; }
      .hl-lr-t { font-size: 0.875rem; font-weight: 700; color: var(--c-text); margin: 0 0 3px; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
      .hl-lr-m { display: flex; align-items: center; gap: 7px; flex-wrap: wrap; }
      .hl-lr-cat { font-size: 0.7rem; color: var(--hl-muted-label); }

      /* ── Show more ── */
      .hl-show-more {
        display: flex; align-items: center; justify-content: center; gap: 6px;
        width: 100%; padding: 10px; margin-top: 8px;
        background: var(--hl-surface); border: 1px dashed var(--hl-border-soft);
        border-radius: var(--hl-radius-sm); cursor: pointer; font-family: inherit;
        font-size: 0.875rem; color: var(--lp-accent); font-weight: 600;
        transition: background 0.12s, border-color 0.12s;
      }
      .hl-show-more:hover { background: var(--hl-accent-weak); border-color: var(--lp-accent); }
      .hl-show-more:focus-visible { outline: 3px solid var(--lp-accent); outline-offset: 2px; }
      .hl-show-more-global {
        display: flex; align-items: center; justify-content: center; gap: 6px;
        margin-top: 16px; padding: 12px 24px; background: var(--hl-surface);
        border: 1px solid var(--hl-border-soft); border-radius: var(--hl-radius);
        cursor: pointer; font-family: inherit; font-size: 0.875rem; color: var(--lp-accent);
        font-weight: 700; transition: background 0.12s, border-color 0.12s; width: 100%;
      }
      .hl-show-more-global:hover { background: var(--hl-accent-weak); border-color: var(--lp-accent); }
      .hl-show-more-global:focus-visible { outline: 3px solid var(--lp-accent); outline-offset: 2px; }

      /* ── Badges ── */
      .hl-badge { font-size: 0.7rem; font-weight: 700; padding: 2px 8px; border-radius: 10px; display: inline-block; }
      .hl-bv { background: var(--hl-badge-video-bg);   color: var(--hl-badge-video-text); }
      .hl-bt { background: var(--hl-badge-tut-bg);     color: var(--hl-badge-tut-text); }
      .hl-bf { background: var(--hl-badge-faq-bg);     color: var(--hl-badge-faq-text); }
      .hl-bn { background: var(--hl-badge-new-bg);     color: var(--hl-badge-new-text); }
      .hl-ico-v { background: var(--hl-badge-video-bg); color: var(--hl-badge-video-text); }
      .hl-ico-t { background: var(--hl-badge-tut-bg);   color: var(--hl-badge-tut-text); }
      .hl-ico-f { background: var(--hl-badge-faq-bg);   color: var(--hl-badge-faq-text); }

      /* ── Featured section header ── */
      .hl-feat-hdr { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
      .hl-feat-hdr-label { font-size: 0.875rem; font-weight: 700; color: var(--c-text); }
      .hl-feat-hdr-line { flex: 1; height: 1px; background: var(--hl-border-soft); }

      /* ── Loading ── */
      .hl-loading { text-align: center; padding: 3rem; color: var(--c-muted); font-size: 0.875rem; }
      .hl-loading-msg { display: block; margin-bottom: 10px; min-height: 1.4em; }
      .hl-loading-dots { display: inline-flex; gap: 5px; }
      .hl-loading-dots span {
        width: 8px; height: 8px; border-radius: 50%;
        background: var(--c-blue20);
        animation: hl-bounce 1.2s infinite ease-in-out;
      }
      .hl-loading-dots span:nth-child(2) { animation-delay: 0.2s; }
      .hl-loading-dots span:nth-child(3) { animation-delay: 0.4s; }
      @keyframes hl-bounce {
        0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
        40%           { transform: scale(1);   opacity: 1; }
      }

      /* ── Empty / error ── */
      .hl-empty {
        text-align: center; padding: 3rem; color: var(--c-muted); font-size: 0.875rem;
        background: var(--hl-surface); border-radius: var(--hl-radius);
        border: 1px solid var(--hl-border-soft);
      }
      .hl-empty .material-symbols-outlined { font-size: 36px; display: block; margin: 0 auto 10px; }
      .hl-empty-reset {
        margin-top: 12px; background: var(--hl-accent-weak);
        border: 1px solid var(--c-blue20); color: var(--lp-accent);
        font-size: 0.8rem; font-weight: 700; padding: 8px 18px;
        border-radius: 20px; cursor: pointer; font-family: inherit;
      }
      .hl-empty-reset:focus-visible { outline: 3px solid var(--lp-accent); outline-offset: 2px; }
      .hl-err {
        text-align: center; padding: 2rem; color: #8a2020; font-size: 0.875rem;
        background: #fff3f3; border-radius: var(--hl-radius); border: 1px solid #f5c6c6;
      }

      /* ── Detail page ── */
      .hl-dpage { display: none; }
      .hl-dpage.on { display: block; }
      .hl-lpage.off { display: none; }

      /* ── Breadcrumb ── */
