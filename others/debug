<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Leadership Hub — LEAF Launchpad</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;600;700;800&family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet" />
  <!-- Material Symbols Outlined — static axes; FILL controlled via CSS only -->
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,400,0,0" />

  <!-- TODO: verify path before production -->
  <link rel="stylesheet" href="/platform/designs/files/launchpad.css" />

  <style>
    /* Filled icons — !important beats launchpad.css FILL:0 and any
       leaf_nav.js injected styles regardless of load order */
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 1, 'wght' 400, 'opsz' 24, 'GRAD' 0 !important;
    }

    #header,
    #footer {
      display: none !important;
    }

    /* ── Page shell ── */
    .ldh-page {
      max-width: 1160px;
      margin: 0 auto;
      padding: 3rem 1.5rem 5rem;
    }

    /* ── Page header ── */
    .ldh-header { margin-bottom: 2.25rem; }

    .ldh-kicker {
      font-family: 'Public Sans', sans-serif;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--lp-accent);
      margin: 0 0 0.5rem;
    }

    .ldh-title {
      font-family: 'Public Sans', sans-serif;
      font-size: clamp(1.6rem, 3vw, 2.15rem);
      font-weight: 800;
      color: var(--lp-hl);
      margin: 0 0 0.4rem;
      line-height: 1.15;
    }

    .ldh-sub {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 1.05rem;
      color: var(--c-muted);
      margin: 0;
      max-width: 640px;
    }

    /* ── Card grid ── */
    .ldh-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.25rem;
    }

    /* ── Cards — shared base ── */
    .ldh-card {
      display: flex;
      flex-direction: column;
      background: #fff;
      border: 1px solid var(--c-blue10);
      border-radius: var(--r-lg);
      padding: 1.375rem;
      text-decoration: none;
      color: inherit;
      box-shadow: 0 2px 12px rgba(0,0,0,.08);
      transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
      cursor: pointer;
      text-align: left;
      font: inherit;
      width: 100%;
      /* reset button styles */
      appearance: none;
      -webkit-appearance: none;
    }

    .ldh-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 28px rgba(0,0,0,.13);
      border-color: var(--c-blue20);
    }

    .ldh-card:focus-visible {
      outline: 3px solid var(--lp-accent);
      outline-offset: 3px;
    }

    /* ── Card top row ── */
    .ldh-card-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.875rem;
    }

    /* ── Icon circle ── */
    .ldh-icon {
      width: 46px;
      height: 46px;
      border-radius: var(--r-lg);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: var(--c-blue5);
      color: var(--lp-hl);
      flex-shrink: 0;
    }

    .ldh-icon .material-symbols-outlined { font-size: 1.5rem !important; }

    /* ── Chips ── */
    .ldh-chip {
      font-family: 'Public Sans', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 999px;
      white-space: nowrap;
    }

    .ldh-chip--live   { background: #dcfce7; color: #166534; }
    .ldh-chip--report { background: var(--c-blue5); color: var(--lp-hl); }

    /* ── Card body ── */
    .ldh-card-title {
      font-family: 'Public Sans', sans-serif;
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--lp-hl);
      margin: 0 0 0.375rem;
    }

    .ldh-card-desc {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.9375rem;
      color: var(--c-muted);
      margin: 0 0 1.125rem;
      flex-grow: 1;
      line-height: 1.55;
    }

    .ldh-card-action {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-family: 'Public Sans', sans-serif;
      font-size: 0.875rem;
      font-weight: 700;
      color: var(--lp-accent);
      margin-top: auto;
    }

    .ldh-card-action .material-symbols-outlined {
      font-size: 1.1rem !important;
      transition: transform 0.15s ease;
    }

    .ldh-card:hover .ldh-card-action .material-symbols-outlined {
      transform: translateX(3px);
    }

    /* ── Footer ── */
    .ldh-footer {
      margin-top: 2.5rem;
      padding-top: 1.25rem;
      border-top: 1px solid var(--c-blue10);
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.85rem;
      color: var(--c-muted);
    }

    /* ── Power BI Modal ── */
    .ldh-modal {
      position: fixed;
      inset: 0;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 20px;
      z-index: 1000;
    }

    .ldh-modal.is-open { display: flex; }

    .ldh-modal__backdrop {
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,.78);
    }

    .ldh-modal__dialog {
      position: relative;
      width: min(1300px, 94vw);
      height: 90vh;
      background: #fff;
      border-radius: var(--r-lg);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      box-shadow: 0 24px 64px rgba(0,0,0,.4);
    }

    .ldh-modal__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem 1rem;
      background: var(--c-blue5);
      border-bottom: 1px solid var(--c-blue20);
      flex-shrink: 0;
    }

    .ldh-modal__title {
      font-family: 'Public Sans', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      color: var(--lp-hl);
      margin: 0;
    }

    .ldh-modal__close {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 38px;
      height: 38px;
      border: 1px solid var(--c-blue20);
      background: #fff;
      color: var(--c-text);
      border-radius: var(--r);
      cursor: pointer;
      font-size: 1.1rem;
      transition: background 0.15s;
      flex-shrink: 0;
    }

    .ldh-modal__close:hover { background: var(--c-blue10); }
    .ldh-modal__close:focus-visible { outline: 3px solid var(--lp-accent); outline-offset: 2px; }

    .ldh-modal__body { flex: 1; min-height: 0; }

    .ldh-modal__frame {
      width: 100%;
      height: 100%;
      border: 0;
    }

    /* ── Responsive ── */
    @media (max-width: 900px) {
      .ldh-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    @media (max-width: 600px) {
      .ldh-grid { grid-template-columns: minmax(0, 1fr); }
      .ldh-page { padding: 2rem 1rem 4rem; }
    }

    @media (prefers-reduced-motion: reduce) {
      .ldh-card,
      .ldh-card-action .material-symbols-outlined { transition: none; }
      .ldh-card:hover { transform: none; }
    }
  </style>

  <!-- TODO: verify path before production -->
  <script src="/platform/designs/files/leaf_nav.js"></script>
</head>
<body>
  <div class="lp" id="lp-root">
    <a class="lp-skip" href="#lp-main">Skip to main content</a>
    <div id="lp-nav-host"></div>

    <!-- Breadcrumb data — must be set before leaf_breadcrumb.js loads -->
    <script>
      window.LEAF_BREADCRUMB = [
        { label: 'Internal', href: '/platform/designs' },
        { label: 'Leadership Hub' }
      ];
    </script>

    <main id="lp-main" tabindex="-1">
      <div class="ldh-page">

        <!-- Header -->
        <header class="ldh-header">
          <p class="ldh-kicker">LEAF Operations</p>
          <h1 class="ldh-title">Leadership Hub</h1>
          <p class="ldh-sub">Internal dashboards, reports, and tools for the LEAF leadership team.</p>
        </header>

        <!-- Card grid -->
        <div class="ldh-grid" role="list">

          <!-- 1. Interactive Map — external link -->
          <a
            class="ldh-card"
            href="https://leaf.va.gov/launchpad/report.php?a=steph_map"
            target="_blank"
            rel="noopener noreferrer"
            role="listitem"
            aria-label="Interactive Map — opens in a new tab"
          >
            <div class="ldh-card-top">
              <span class="ldh-icon" aria-hidden="true">
                <span class="material-symbols-outlined">map</span>
              </span>
              <span class="ldh-chip ldh-chip--live">Live</span>
            </div>
            <h2 class="ldh-card-title">Interactive Map</h2>
            <p class="ldh-card-desc">Search facilities using LEAF and explore national usage, adoption and utilization rates, and top use cases.</p>
            <span class="ldh-card-action" aria-hidden="true">
              Open map
              <span class="material-symbols-outlined">open_in_new</span>
            </span>
          </a>

          <!-- 2. Project Dashboard — external link -->
          <a
            class="ldh-card"
            href="https://leaf.va.gov/platform/projects/"
            target="_blank"
            rel="noopener noreferrer"
            role="listitem"
            aria-label="Project Dashboard — opens in a new tab"
          >
            <div class="ldh-card-top">
              <span class="ldh-icon" aria-hidden="true">
                <span class="material-symbols-outlined">dashboard</span>
              </span>
              <span class="ldh-chip ldh-chip--live">Live</span>
            </div>
            <h2 class="ldh-card-title">Project Dashboard</h2>
            <p class="ldh-card-desc">Team tracker for projects, tasks, and OKRs across the LEAF team.</p>
            <span class="ldh-card-action" aria-hidden="true">
              Open dashboard
              <span class="material-symbols-outlined">open_in_new</span>
            </span>
          </a>

          <!-- 3. Power BI: Support Services -->
          <button
            class="ldh-card"
            type="button"
            role="listitem"
            aria-label="Support Services — view Power BI report"
            data-report-title="LEAF Support Services Dashboard v3"
            data-report-src="https://app.powerbigov.us/reportEmbed?reportId=4edaaa11-3794-4ceb-bacd-15978d94415d&appId=bc14ee51-602f-4786-842e-f6162f360b9b&autoAuth=true&ctid=e95f1b23-abaf-45ee-821d-b7ab251ab3bf"
          >
            <div class="ldh-card-top">
              <span class="ldh-icon" aria-hidden="true">
                <span class="material-symbols-outlined">support_agent</span>
              </span>
              <span class="ldh-chip ldh-chip--report">Power BI</span>
            </div>
            <h2 class="ldh-card-title">Support Services</h2>
            <p class="ldh-card-desc">Service volume, response times, and support performance metrics.</p>
            <span class="ldh-card-action" aria-hidden="true">
              View report
              <span class="material-symbols-outlined">arrow_forward</span>
            </span>
          </button>

          <!-- 4. Power BI: Customer Feedback -->
          <button
            class="ldh-card"
            type="button"
            role="listitem"
            aria-label="Customer Feedback — view Power BI report"
            data-report-title="LEAF Customer Feedback Dashboard (v2)"
            data-report-src="https://app.powerbigov.us/reportEmbed?reportId=962c98ea-2211-4403-aa35-076b453a47a1&appId=bc14ee51-602f-4786-842e-f6162f360b9b&autoAuth=true&ctid=e95f1b23-abaf-45ee-821d-b7ab251ab3bf"
          >
            <div class="ldh-card-top">
              <span class="ldh-icon" aria-hidden="true">
                <span class="material-symbols-outlined">reviews</span>
              </span>
              <span class="ldh-chip ldh-chip--report">Power BI</span>
            </div>
            <h2 class="ldh-card-title">Customer Feedback</h2>
            <p class="ldh-card-desc">Satisfaction scores, sentiment, and feedback trends over time.</p>
            <span class="ldh-card-action" aria-hidden="true">
              View report
              <span class="material-symbols-outlined">arrow_forward</span>
            </span>
          </button>

          <!-- 5. Power BI: Community Ideas -->
          <button
            class="ldh-card"
            type="button"
            role="listitem"
            aria-label="Community Ideas — view Power BI report"
            data-report-title="LEAF Ideas"
            data-report-src="https://app.powerbigov.us/reportEmbed?reportId=76d43845-3a03-49c0-a8b3-1c121be0c8e7&appId=bc14ee51-602f-4786-842e-f6162f360b9b&autoAuth=true&ctid=e95f1b23-abaf-45ee-821d-b7ab251ab3bf"
          >
            <div class="ldh-card-top">
              <span class="ldh-icon" aria-hidden="true">
                <span class="material-symbols-outlined">lightbulb</span>
              </span>
              <span class="ldh-chip ldh-chip--report">Power BI</span>
            </div>
            <h2 class="ldh-card-title">Community Ideas</h2>
            <p class="ldh-card-desc">Submitted ideas from the LEAF Community, voting activity, and status.</p>
            <span class="ldh-card-action" aria-hidden="true">
              View report
              <span class="material-symbols-outlined">arrow_forward</span>
            </span>
          </button>

        </div><!-- /.ldh-grid -->

        <footer class="ldh-footer" role="contentinfo">
          Last updated automatically · Internal use only
        </footer>

      </div><!-- /.ldh-page -->
    </main>

    <!-- Power BI Modal -->
    <div
      class="ldh-modal"
      id="ldhModal"
      role="dialog"
      aria-modal="true"
      aria-labelledby="ldhModalTitle"
      aria-hidden="true"
    >
      <div class="ldh-modal__backdrop" id="ldhModalBackdrop"></div>
      <div class="ldh-modal__dialog">
        <div class="ldh-modal__header">
          <h2 class="ldh-modal__title" id="ldhModalTitle">Report</h2>
          <button
            class="ldh-modal__close"
            id="ldhModalClose"
            type="button"
            aria-label="Close report"
          >
            <span class="material-symbols-outlined" aria-hidden="true">close</span>
          </button>
        </div>
        <div class="ldh-modal__body">
          <iframe
            class="ldh-modal__frame"
            id="ldhModalFrame"
            title="Power BI report"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>

    <button
      class="lp-jump"
      id="lpJump"
      type="button"
      aria-label="Back to top"
      aria-hidden="true"
      tabindex="-1"
    >
      <span class="material-symbols-outlined" aria-hidden="true">arrow_upward</span>
    </button>
  </div><!-- /.lp -->

  <!-- Breadcrumb — loaded at end of body so DOM is ready -->
  <!-- TODO: verify path before production -->
  <script src="/platform/designs/files/leaf_breadcrumb.js"></script>

  <script>
    (() => {
      'use strict';

      const $id = (id) => document.getElementById(id);

      /* ── Power BI modal ── */
      (() => {
        const modal      = $id('ldhModal');
        const frame      = $id('ldhModalFrame');
        const titleEl    = $id('ldhModalTitle');
        const closeBtn   = $id('ldhModalClose');
        const backdrop   = $id('ldhModalBackdrop');
        if (!modal || !frame || !closeBtn) return;

        let lastFocused = null;

        const openModal = (src, title) => {
          lastFocused = document.activeElement;
          titleEl.textContent = title || 'Report';
          frame.src = src;
          modal.classList.add('is-open');
          modal.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
          closeBtn.focus();
        };

        const closeModal = () => {
          modal.classList.remove('is-open');
          modal.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
          /* Stop the iframe — frees resources and stops audio/video */
          frame.src = '';
          lastFocused?.focus();
        };

        /* Wire all Power BI button cards */
        document.querySelectorAll('.ldh-card[data-report-src]').forEach((card) => {
          card.addEventListener('click', () => {
            openModal(
              card.getAttribute('data-report-src'),
              card.getAttribute('data-report-title')
            );
          });
        });

        closeBtn.addEventListener('click', closeModal);
        backdrop.addEventListener('click', closeModal);

        /* Escape closes modal */
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
        });

        /* Focus trap inside modal */
        modal.addEventListener('keydown', (e) => {
          if (e.key !== 'Tab' || !modal.classList.contains('is-open')) return;
          const focusable = Array.from(
            modal.querySelectorAll('button:not([disabled]), [tabindex]:not([tabindex="-1"])')
          );
          if (!focusable.length) return;
          const first = focusable[0];
          const last  = focusable[focusable.length - 1];
          if (e.shiftKey && document.activeElement === first) {
            e.preventDefault();
            last.focus();
          } else if (!e.shiftKey && document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        });
      })();

      /* ── Jump to top ── */
      (() => {
        const btn = $id('lpJump');
        if (!btn) return;
        const update = () => {
          const vis = (window.pageYOffset || document.documentElement.scrollTop) > 120;
          btn.classList.toggle('vis', vis);
          btn.setAttribute('aria-hidden', String(!vis));
          btn.tabIndex = vis ? 0 : -1;
        };
        btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
        window.addEventListener('scroll', update, { passive: true });
        window.addEventListener('resize', update);
        update();
      })();

    })();
  </script>
</body>
</html>
