    <script>
      /* ── Image protection ── */
      document.addEventListener('contextmenu', (e) => {
        if (e.target.tagName === 'IMG') e.preventDefault();
      });
      document.addEventListener('dragstart', (e) => {
        if (e.target.tagName === 'IMG') e.preventDefault();
      });

      /* ── Jump-to-top ── */
      (() => {
        const btn = document.getElementById('lpJump');
        if (!btn) return;

        function update() {
          const swapHost = document.getElementById('lpSwapHost');
          const top =
            (swapHost && !swapHost.hasAttribute('hidden') ? swapHost.scrollTop : 0) ||
            window.pageYOffset ||
            document.documentElement.scrollTop;
          const vis = top > 120;
          btn.classList.toggle('vis', vis);
          btn.setAttribute('aria-hidden', String(!vis));
          btn.tabIndex = vis ? 0 : -1;
        }

        btn.addEventListener('click', () => {
          const swapHost = document.getElementById('lpSwapHost');
          if (swapHost && !swapHost.hasAttribute('hidden')) {
            swapHost.scrollTo({ top: 0, behavior: 'smooth' });
          } else {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          }
        });

        window.addEventListener('scroll', update, { passive: true });
        window.addEventListener('resize', update);
        document.addEventListener('scroll', (e) => {
          if (e.target?.id === 'lpSwapHost') update();
        }, { passive: true, capture: true });

        update();
      })();

      /* ── Demo modal ── */
      (() => {
        const modal   = document.getElementById('lpDemoModal');
        const frame   = document.getElementById('lpDemoFrame');
        const openBtn = document.getElementById('lpDemoBtn');
        const closeBtn = document.getElementById('lpDemoClose');
        if (!modal || !frame || !openBtn || !closeBtn) return;

        const src = frame.getAttribute('data-src');

        const openModal = () => {
          frame.src = src;
          modal.removeAttribute('hidden');
          document.body.style.overflow = 'hidden';
          closeBtn.focus();
        };

        const closeModal = () => {
          frame.src = '';
          modal.setAttribute('hidden', '');
          document.body.style.overflow = '';
          openBtn.focus();
        };

        openBtn.addEventListener('click', openModal);
        closeBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && !modal.hasAttribute('hidden')) closeModal();
        });
        modal.addEventListener('keydown', (e) => {
          if (e.key === 'Tab' && !modal.hasAttribute('hidden')) {
            e.preventDefault();
            closeBtn.focus();
          }
        });
      })();

      /* ── Newsletter form ── */
      (() => {
        const form  = document.getElementById('lpNlForm');
        const input = document.getElementById('lpNlEmail');
        if (!form || !input) return;

        form.addEventListener('submit', (e) => {
          e.preventDefault();
          if (!input.value || !input.value.includes('@')) {
            input.setCustomValidity('Please enter a valid VA email address.');
            input.reportValidity();
            return;
          }
          input.setCustomValidity('');
          /* TODO: wire to subscription endpoint */
        });

        input.addEventListener('input', () => { input.setCustomValidity(''); });
      })();
    </script>
  
