<!--
    UX ROADMAP — LEAF Programmer Page
    ===================================
    This page queries a LEAF form to display UX roadmap themes
    organized into Now / Next / Future time horizons.
-->

<style>
  /* ============================================================
   UX ROADMAP STYLES
   ============================================================ */

  #uxRoadmap * {
    box-sizing: border-box;
  }

  #uxRoadmap {
    font-family:
      -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial,
      sans-serif;
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px;
    color: #1a1a1a;
  }

  /* Header */
  .rm-header {
    border-bottom: 2px solid #e0e0e0;
    padding-bottom: 16px;
    margin-bottom: 20px;
  }
  .rm-title {
    font-size: 22px;
    font-weight: 600;
    margin: 0 0 6px 0;
  }
  .rm-meta {
    font-size: 13px;
    color: #666;
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }
  .rm-vision {
    font-size: 13px;
    color: #444;
    padding: 10px 14px;
    background: #f5f5f0;
    border-left: 3px solid #003f72;
    margin-top: 10px;
    font-style: italic;
  }

  /* Toolbar */
  .rm-toolbar {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
    flex-wrap: wrap;
    align-items: center;
  }
  .rm-toolbar label {
    font-size: 13px;
    color: #555;
    font-weight: 600;
  }
  .rm-filter-btn {
    font-size: 12px;
    padding: 5px 14px;
    border-radius: 20px;
    border: 1px solid #ccc;
    background: #fff;
    color: #555;
    cursor: pointer;
    transition: all 0.15s;
  }
  .rm-filter-btn:hover {
    background: #f0f0f0;
    border-color: #aaa;
  }
  .rm-filter-btn.active {
    background: #003f72;
    color: #fff;
    border-color: #003f72;
  }
  .rm-spacer {
    flex: 1;
  }
  .rm-add-btn {
    font-size: 13px;
    padding: 5px 16px;
    border-radius: 4px;
    border: 1px solid #003f72;
    background: #fff;
    color: #003f72;
    cursor: pointer;
    font-weight: 600;
  }
  .rm-add-btn:hover {
    background: #003f72;
    color: #fff;
  }

  /* Loading */
  .rm-loading {
    text-align: center;
    padding: 60px 20px;
    font-size: 16px;
    color: #888;
  }

  /* Error */
  .rm-error {
    text-align: center;
    padding: 40px 20px;
    color: #b00;
    font-size: 14px;
  }

  /* Empty state */
  .rm-empty {
    text-align: center;
    padding: 40px 20px;
    color: #888;
    font-size: 14px;
    border: 1px dashed #ccc;
    border-radius: 8px;
    margin: 8px 0;
  }

  /* Three columns */
  .rm-columns {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    align-items: start;
  }
  @media (max-width: 900px) {
    .rm-columns {
      grid-template-columns: 1fr;
    }
  }

  /* Column header */
  .rm-col-header {
    font-size: 13px;
    font-weight: 700;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 8px 0;
    border-bottom: 3px solid #ccc;
    margin-bottom: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .rm-col-header .rm-count {
    font-size: 11px;
    font-weight: 400;
    background: #eee;
    padding: 2px 10px;
    border-radius: 12px;
    color: #666;
  }
  .rm-col-now .rm-col-header {
    border-bottom-color: #2e8540;
  }
  .rm-col-next .rm-col-header {
    border-bottom-color: #0071bc;
  }
  .rm-col-future .rm-col-header {
    border-bottom-color: #6b3a9e;
  }

  /* Theme cards */
  .rm-card {
    background: #fff;
    border: 1px solid #d6d7d9;
    border-radius: 6px;
    padding: 14px 16px;
    margin-bottom: 10px;
    cursor: pointer;
    transition:
      border-color 0.15s,
      box-shadow 0.15s;
  }
  .rm-card:hover {
    border-color: #aeb0b5;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }
  .rm-card.expanded {
    border-color: #003f72;
    box-shadow: 0 2px 8px rgba(0, 63, 114, 0.1);
  }

  .rm-card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 8px;
  }
  .rm-card-title {
    font-size: 14px;
    font-weight: 600;
    color: #1a1a1a;
    line-height: 1.4;
  }
  .rm-card-title a {
    color: #003f72;
    text-decoration: none;
  }
  .rm-card-title a:hover {
    text-decoration: underline;
  }

  /* Confidence badges */
  .rm-badge {
    font-size: 11px;
    padding: 2px 10px;
    border-radius: 12px;
    white-space: nowrap;
    flex-shrink: 0;
    font-weight: 600;
  }
  .rm-badge-high {
    background: #e7f4e4;
    color: #2e8540;
  }
  .rm-badge-medium {
    background: #fff1d2;
    color: #8b6914;
  }
  .rm-badge-low {
    background: #f9dede;
    color: #981b1e;
  }

  /* Beneficiary line */
  .rm-card-beneficiary {
    font-size: 12px;
    color: #555;
    margin-top: 6px;
    line-height: 1.5;
  }
  .rm-card-beneficiary strong {
    font-weight: 600;
    color: #1a1a1a;
  }

  /* Product area tag */
  .rm-area-tag {
    display: inline-block;
    font-size: 11px;
    padding: 2px 10px;
    border-radius: 12px;
    margin-top: 8px;
    background: #f1f1f1;
    color: #555;
    border: 1px solid #e0e0e0;
  }

  /* Expandable details */
  .rm-card-details {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.3s ease;
  }
  .rm-card.expanded .rm-card-details {
    max-height: 500px;
  }

  .rm-detail-section {
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px solid #e8e8e8;
  }
  .rm-detail-label {
    font-size: 11px;
    font-weight: 700;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 4px;
  }
  .rm-detail-value {
    font-size: 13px;
    color: #444;
    line-height: 1.5;
  }

  /* Owner */
  .rm-owner {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: #555;
    margin-top: 8px;
  }
  .rm-owner-dot {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #003f72;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 9px;
    font-weight: 700;
    color: #fff;
  }

  /* Legend */
  .rm-legend {
    display: flex;
    gap: 20px;
    margin-top: 20px;
    padding-top: 14px;
    border-top: 1px solid #e0e0e0;
    font-size: 12px;
    color: #888;
    flex-wrap: wrap;
  }
  .rm-legend-item {
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .rm-legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  /* Record link */
  .rm-record-link {
    display: inline-block;
    margin-top: 8px;
    font-size: 12px;
    color: #003f72;
    text-decoration: none;
  }
  .rm-record-link:hover {
    text-decoration: underline;
  }
</style>

<div id="uxRoadmap">
  <div class="rm-header">
    <div class="rm-title" id="rmTitle">UX Roadmap</div>
    <div class="rm-meta">
      <span id="rmOwner"></span>
      <span id="rmDate"></span>
    </div>
    <div class="rm-vision" id="rmVision">
      Edit the title, owner, date, and vision text in the CONFIGURATION section
      of this page's source code.
    </div>
  </div>

  <div class="rm-toolbar" id="rmToolbar">
    <label>Filter:</label>
    <button
      class="rm-filter-btn active"
      onclick="roadmap.filterCards('all', this)"
    >
      All
    </button>
    <!-- dynamic filter buttons injected here -->
    <span class="rm-spacer"></span>
    <button
      class="rm-add-btn"
      id="rmAddBtn"
      style="display: none"
      onclick="roadmap.createNewTheme()"
    >
      + New Theme
    </button>
  </div>

  <div class="rm-loading" id="rmLoading">
    <img src="images/indicator.gif" alt="" style="vertical-align: middle" />
    Loading roadmap...
  </div>

  <div class="rm-columns" id="rmColumns" style="display: none">
    <div class="rm-col-now">
      <div class="rm-col-header">
        Now <span class="rm-count" id="rmCountNow">0</span>
      </div>
      <div id="rmCardsNow"></div>
    </div>
    <div class="rm-col-next">
      <div class="rm-col-header">
        Next <span class="rm-count" id="rmCountNext">0</span>
      </div>
      <div id="rmCardsNext"></div>
    </div>
    <div class="rm-col-future">
      <div class="rm-col-header">
        Future <span class="rm-count" id="rmCountFuture">0</span>
      </div>
      <div id="rmCardsFuture"></div>
    </div>
  </div>

  <div class="rm-error" id="rmError" style="display: none"></div>

  <div class="rm-legend" id="rmLegend" style="display: none">
    <div class="rm-legend-item">
      <div class="rm-legend-dot" style="background: #2e8540"></div>
      Now — in progress
    </div>
    <div class="rm-legend-item">
      <div class="rm-legend-dot" style="background: #0071bc"></div>
      Next — near future
    </div>
    <div class="rm-legend-item">
      <div class="rm-legend-dot" style="background: #6b3a9e"></div>
      Future — 6+ months
    </div>
    <span class="rm-spacer"></span>
    <div class="rm-legend-item">Confidence:</div>
    <div class="rm-legend-item">
      <span class="rm-badge rm-badge-high">High</span>
    </div>
    <div class="rm-legend-item">
      <span class="rm-badge rm-badge-medium">Medium</span>
    </div>
    <div class="rm-legend-item">
      <span class="rm-badge rm-badge-low">Low</span>
    </div>
  </div>
</div>

<script>
  /* ============================================================
   CONFIGURATION — UPDATE THESE VALUES FOR YOUR LEAF SITE
   ============================================================ */
  var ROADMAP_CONFIG = {
    // The categoryID of your UX Roadmap form
    categoryID: "form_50725", // e.g. 'form_a1b2c'

    // Indicator IDs — update these after creating the form
    INDICATOR_TITLE: 10, // Theme Title (text)
    INDICATOR_BENEFICIARY: 11, // Beneficiary (text)
    INDICATOR_NEED: 12, // User Need (textarea)
    INDICATOR_OUTCOME: 13, // Business Outcome (textarea)
    INDICATOR_OWNER: 14, // Owner / Team (text)
    INDICATOR_WORK: 15, // Work Type (textarea)
    INDICATOR_HORIZON: 16, // Time Horizon (dropdown: Now, Next, Future)
    INDICATOR_PRIORITY: 17, // Priority (number)
    INDICATOR_AREA: 18, // Product Area (dropdown)
    INDICATOR_CONFIDENCE: 19, // Confidence (dropdown: High, Medium, Low)
    INDICATOR_SUBTHEMES: 20, // Subthemes (textarea)

    // Page display settings
    pageTitle: "UX Roadmap",
    owner: "UX Design Team",
    vision:
      "Prioritize and communicate UX work to align designers, researchers, developers, and stakeholders around a shared vision.",

    // Set to the categoryID number to enable "New Theme" button.
    // Leave as '' to hide the button.
    newFormCategoryID: "", // e.g. 'form_a1b2c'
  };

  /* ============================================================
   ROADMAP APPLICATION
   ============================================================ */
  var roadmap = (function () {
    var themes = [];
    var productAreas = [];
    var currentFilter = "all";

    /**
     * Initialize the roadmap
     */
    function init() {
      // Set header info
      $("#rmTitle").text(ROADMAP_CONFIG.pageTitle);
      $("#rmOwner").text("Owner: " + ROADMAP_CONFIG.owner);
      $("#rmDate").text(
        "Updated: " +
          new Date().toLocaleDateString("en-US", {
            year: "numeric",
            month: "short",
            day: "numeric",
          }),
      );
      $("#rmVision").text(ROADMAP_CONFIG.vision);

      // Show "New Theme" button if configured
      if (ROADMAP_CONFIG.newFormCategoryID) {
        $("#rmAddBtn").show();
      }

      // Validate config
      if (!ROADMAP_CONFIG.categoryID) {
        showError(
          "Configuration needed: Set the categoryID and indicator IDs in the ROADMAP_CONFIG section of this page. See source code comments for setup instructions.",
        );
        return;
      }

      loadData();
    }

    /**
     * Query LEAF for all roadmap theme records
     */
    function loadData() {
      var indicatorIDs = [
        ROADMAP_CONFIG.INDICATOR_TITLE,
        ROADMAP_CONFIG.INDICATOR_BENEFICIARY,
        ROADMAP_CONFIG.INDICATOR_NEED,
        ROADMAP_CONFIG.INDICATOR_OUTCOME,
        ROADMAP_CONFIG.INDICATOR_OWNER,
        ROADMAP_CONFIG.INDICATOR_WORK,
        ROADMAP_CONFIG.INDICATOR_HORIZON,
        ROADMAP_CONFIG.INDICATOR_PRIORITY,
        ROADMAP_CONFIG.INDICATOR_AREA,
        ROADMAP_CONFIG.INDICATOR_CONFIDENCE,
        ROADMAP_CONFIG.INDICATOR_SUBTHEMES,
      ];

      var query = new LeafFormQuery();
      query.addTerm("categoryID", "=", ROADMAP_CONFIG.categoryID);
      query.addTerm("stepID", "=", "notDeleted");
      query.getData(indicatorIDs);
      query.join("status");

      query
        .execute()
        .then(function (results) {
          processResults(results);
        })
        .catch(function (err) {
          console.error("Roadmap query error:", err);
          showError(
            "Error loading roadmap data. Please check the console for details.",
          );
        });
    }

    /**
     * Process query results into theme objects
     */
    function processResults(results) {
      themes = [];
      var areaSet = {};

      for (var recordID in results) {
        if (!results.hasOwnProperty(recordID)) continue;
        var r = results[recordID];
        var s1 = r.s1 || {};

        var theme = {
          recordID: recordID,
          title: getVal(s1, ROADMAP_CONFIG.INDICATOR_TITLE),
          beneficiary: getVal(s1, ROADMAP_CONFIG.INDICATOR_BENEFICIARY),
          need: getVal(s1, ROADMAP_CONFIG.INDICATOR_NEED),
          outcome: getVal(s1, ROADMAP_CONFIG.INDICATOR_OUTCOME),
          owner: getVal(s1, ROADMAP_CONFIG.INDICATOR_OWNER),
          work: getVal(s1, ROADMAP_CONFIG.INDICATOR_WORK),
          horizon: normalizeHorizon(
            getVal(s1, ROADMAP_CONFIG.INDICATOR_HORIZON),
          ),
          priority:
            parseInt(getVal(s1, ROADMAP_CONFIG.INDICATOR_PRIORITY)) || 99,
          area: getVal(s1, ROADMAP_CONFIG.INDICATOR_AREA),
          confidence: normalizeConfidence(
            getVal(s1, ROADMAP_CONFIG.INDICATOR_CONFIDENCE),
          ),
          subthemes: getVal(s1, ROADMAP_CONFIG.INDICATOR_SUBTHEMES),
        };

        // Only include themes that have a title and a valid horizon
        if (theme.title && theme.horizon) {
          themes.push(theme);
          if (theme.area) {
            areaSet[theme.area] = true;
          }
        }
      }

      // Sort by priority within each horizon
      themes.sort(function (a, b) {
        return a.priority - b.priority;
      });

      // Build filter buttons for product areas
      productAreas = Object.keys(areaSet).sort();
      buildFilterButtons();

      // Render
      $("#rmLoading").hide();
      $("#rmColumns").show();
      $("#rmLegend").show();
      renderCards(currentFilter);
    }

    /**
     * Extract a value from the query result by indicatorID
     */
    function getVal(series, indicatorID) {
      if (!indicatorID) return "";
      var key = "id" + indicatorID;
      if (series[key] && series[key].value !== undefined) {
        var val = series[key].value;
        // Handle array values (multiselect, checkboxes)
        if (Array.isArray(val)) {
          return val
            .filter(function (v) {
              return v && v !== "no";
            })
            .join(", ");
        }
        return (val || "").toString().trim();
      }
      return "";
    }

    /**
     * Normalize horizon value to lowercase
     */
    function normalizeHorizon(val) {
      if (!val) return "";
      var v = val.toLowerCase().trim();
      if (v === "now" || v === "next" || v === "future") return v;
      return "";
    }

    /**
     * Normalize confidence value
     */
    function normalizeConfidence(val) {
      if (!val) return "medium";
      var v = val.toLowerCase().trim();
      if (v === "high" || v === "medium" || v === "low") return v;
      return "medium";
    }

    /**
     * Build dynamic filter buttons from product areas
     */
    function buildFilterButtons() {
      var toolbar = $("#rmToolbar");
      // Remove old dynamic buttons (keep the "All" button and label)
      toolbar.find(".rm-filter-dynamic").remove();

      var spacer = toolbar.find(".rm-spacer");
      for (var i = 0; i < productAreas.length; i++) {
        var area = productAreas[i];
        var btn = $("<button>")
          .addClass("rm-filter-btn rm-filter-dynamic")
          .text(area)
          .attr("data-area", area)
          .on("click", function () {
            roadmap.filterCards($(this).attr("data-area"), this);
          });
        btn.insertBefore(spacer);
      }
    }

    /**
     * Render theme cards into the three columns
     */
    function renderCards(filter) {
      currentFilter = filter;
      var horizons = ["now", "next", "future"];

      for (var h = 0; h < horizons.length; h++) {
        var horizon = horizons[h];
        var containerId =
          "#rmCards" + horizon.charAt(0).toUpperCase() + horizon.slice(1);
        var countId =
          "#rmCount" + horizon.charAt(0).toUpperCase() + horizon.slice(1);
        var container = $(containerId);
        container.empty();

        var filtered = themes.filter(function (t) {
          return (
            t.horizon === horizon && (filter === "all" || t.area === filter)
          );
        });

        $(countId).text(filtered.length);

        if (filtered.length === 0) {
          container.append('<div class="rm-empty">No themes</div>');
          continue;
        }

        for (var i = 0; i < filtered.length; i++) {
          container.append(buildCard(filtered[i]));
        }
      }
    }

    /**
     * Build a single theme card HTML
     */
    function buildCard(theme) {
      var confClass = "rm-badge-" + theme.confidence;
      var confLabel =
        theme.confidence.charAt(0).toUpperCase() + theme.confidence.slice(1);
      var initials = getInitials(theme.owner);

      var html = '<div class="rm-card" onclick="roadmap.toggleCard(this)">';

      // Top row: title + confidence badge
      html += '<div class="rm-card-top">';
      html +=
        '<div class="rm-card-title">' + escapeHtml(theme.title) + "</div>";
      html +=
        '<span class="rm-badge ' + confClass + '">' + confLabel + "</span>";
      html += "</div>";

      // Beneficiary + need
      if (theme.beneficiary || theme.need) {
        html += '<div class="rm-card-beneficiary">';
        if (theme.beneficiary) {
          html += "<strong>" + escapeHtml(theme.beneficiary) + "</strong>";
        }
        if (theme.need) {
          html += (theme.beneficiary ? " — " : "") + escapeHtml(theme.need);
        }
        html += "</div>";
      }

      // Product area tag
      if (theme.area) {
        html +=
          '<span class="rm-area-tag">' + escapeHtml(theme.area) + "</span>";
      }

      // Expandable details
      html += '<div class="rm-card-details">';

      // Business outcome
      if (theme.outcome) {
        html += '<div class="rm-detail-section">';
        html += '<div class="rm-detail-label">Business Outcome</div>';
        html +=
          '<div class="rm-detail-value">' +
          escapeHtml(theme.outcome) +
          "</div>";
        html += "</div>";
      }

      // Work involved
      if (theme.work) {
        html += '<div class="rm-detail-section">';
        html += '<div class="rm-detail-label">Work Involved</div>';
        html +=
          '<div class="rm-detail-value">' + escapeHtml(theme.work) + "</div>";
        html += "</div>";
      }

      // Subthemes
      if (theme.subthemes) {
        html += '<div class="rm-detail-section">';
        html += '<div class="rm-detail-label">Subthemes</div>';
        html +=
          '<div class="rm-detail-value">' +
          escapeHtml(theme.subthemes) +
          "</div>";
        html += "</div>";
      }

      // Owner
      if (theme.owner) {
        html += '<div class="rm-owner">';
        html +=
          '<span class="rm-owner-dot">' + escapeHtml(initials) + "</span>";
        html += escapeHtml(theme.owner);
        html += "</div>";
      }

      // Link to LEAF record
      html +=
        '<a class="rm-record-link" href="index.php?a=printview&recordID=' +
        theme.recordID +
        '" ';
      html += 'onclick="event.stopPropagation()" target="_blank">';
      html += "Open record #" + theme.recordID + " →</a>";

      html += "</div>"; // end details
      html += "</div>"; // end card

      return html;
    }

    /**
     * Toggle card expanded state
     */
    function toggleCard(el) {
      $(el).toggleClass("expanded");
    }

    /**
     * Filter cards by product area
     */
    function filterCards(area, btnEl) {
      $(".rm-filter-btn").removeClass("active");
      $(btnEl).addClass("active");
      renderCards(area);
    }

    /**
     * Create a new roadmap theme via LEAF form
     */
    function createNewTheme() {
      if (!ROADMAP_CONFIG.newFormCategoryID) return;
      // Navigate to new form creation
      window.location.href =
        "index.php?a=newform&formID=" + ROADMAP_CONFIG.newFormCategoryID;
    }

    /**
     * Get initials from a name/team string
     */
    function getInitials(name) {
      if (!name) return "?";
      var parts = name.trim().split(/\s+/);
      if (parts.length >= 2) {
        return (parts[0][0] + parts[1][0]).toUpperCase();
      }
      return parts[0].substring(0, 2).toUpperCase();
    }

    /**
     * Basic HTML escaping
     */
    function escapeHtml(str) {
      if (!str) return "";
      return str
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");
    }

    /**
     * Show error message
     */
    function showError(msg) {
      $("#rmLoading").hide();
      $("#rmError").html(msg).show();
    }

    // Public API
    return {
      init: init,
      toggleCard: toggleCard,
      filterCards: filterCards,
      createNewTheme: createNewTheme,
    };
  })();

  /* Initialize when DOM is ready */
  $(function () {
    roadmap.init();
  });
</script>
