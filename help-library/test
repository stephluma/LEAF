<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>VA LEAF — Help Library</title>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,400,0,0" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet" />
<style>
.hl-root {
  --hl-navy-deep:      #1a4480;
  --hl-navy-mid:       #1f5796;
  --hl-navy-light:     #2570b5;
  --hl-hero-gradient:  linear-gradient(135deg,#e8f0f9 0%,#f3f3f3 60%,#d6ead6 100%);

  --hl-badge-video-bg:   #EBF4FF; --hl-badge-video-text: #1a4480;
  --hl-badge-tut-bg:     #E6F9F2; --hl-badge-tut-text:   #0a6e4e;
  --hl-badge-faq-bg:     #FEF3E2; --hl-badge-faq-text:   #8a5800;
  --hl-badge-new-bg:     #EDFCE7; --hl-badge-new-text:   #267a1e;

  --hl-start-bg:       #fffbeb;
  --hl-start-border:   #f59e0b;
  --hl-start-icon:     #92400e;

  --hl-muted-label:    #6b7280;
  --hl-border-soft:    var(--lp-border,        #cfd7e3);
  --hl-surface:        var(--lp-panel,         #ffffff);
  --hl-bg:             var(--lp-bg,            #f3f3f3);
  --hl-accent:         var(--lp-accent,        #005ea2);
  --hl-accent-strong:  var(--lp-accent-strong, #004a82);
  --hl-accent-weak:    var(--lp-accent-weak,   #cce4f5);
  --hl-radius:         var(--lp-radius,        14px);
  --hl-radius-sm:      var(--radius-sm,        10px);
  --hl-shadow:         var(--lp-shadow,        0 10px 30px rgba(15,23,42,.08));

  --hl-row-border-video:   #1a56a8;
  --hl-row-border-tutorial:#0a6e4e;
  --hl-row-border-faq:     #8a5800;

  min-height: 100vh;
  background: var(--hl-bg);
  font-family: 'Source Sans 3','Source Sans Pro',sans-serif;
  color: var(--lp-text,#0f172a);
  font-size: 1rem;
}

/* ── Skip link ── */
.hl-skip {
  position: absolute; left: 16px; top: 16px; padding: 8px 14px;
  background: #fff; border: 2px solid var(--hl-accent); color: var(--hl-accent);
  border-radius: 8px; font-weight: 700; font-size: .875rem; text-decoration: none;
  transform: translateY(-200%); transition: transform .15s ease; z-index: 3000;
}
.hl-skip:focus { transform: translateY(0); outline: 3px solid var(--hl-accent); outline-offset: 2px; }

/* ── Icon overrides ── */
.hl-root .hl-sbox-btn .material-symbols-outlined              { color: #ffffff !important; }
.hl-root .hl-hero .material-symbols-outlined                  { color: var(--hl-accent) !important; }
.hl-root .hl-cat-strip .material-symbols-outlined             { color: var(--lp-muted,#475569) !important; }
.hl-root .hl-ctab.on .material-symbols-outlined               { color: var(--hl-accent) !important; }
.hl-root .hl-sbr .material-symbols-outlined                   { color: var(--lp-muted,#475569) !important; }
.hl-root .hl-sbr.on .material-symbols-outlined                { color: var(--hl-accent) !important; }
.hl-root .hl-spill .material-symbols-outlined                 { color: var(--lp-muted,#475569) !important; }
.hl-root .hl-spill.on .material-symbols-outlined              { color: var(--hl-accent) !important; }
.hl-root .hl-dbc .material-symbols-outlined                   { color: var(--hl-accent) !important; }
.hl-root .hl-dhero .material-symbols-outlined                 { color: var(--hl-accent) !important; }
.hl-root .hl-dhico .material-symbols-outlined                 { color: var(--hl-accent) !important; }
.hl-root .hl-dact .material-symbols-outlined                  { color: var(--lp-muted,#475569) !important; }
.hl-root .hl-dact:hover .material-symbols-outlined            { color: var(--hl-accent) !important; }
.hl-root .hl-dmeta-row .material-symbols-outlined             { color: var(--hl-muted-label) !important; }
.hl-root .hl-empty .material-symbols-outlined                 { color: var(--hl-border-soft) !important; }
.hl-root .hl-fc-ico .material-symbols-outlined,
.hl-root .hl-lr-ico .material-symbols-outlined,
.hl-root .hl-drii  .material-symbols-outlined                 { color: inherit !important; }
.hl-root .hl-lr-arr, .hl-root .hl-drel-arr                   { color: var(--hl-border-soft) !important; }
.hl-root .hl-pdf-close .material-symbols-outlined             { color: #ffffff !important; }
.hl-root .hl-vid-fallback-ico .material-symbols-outlined      { color: #fff !important; }
.hl-root .hl-grp-hdr .material-symbols-outlined               { color: var(--hl-muted-label) !important; }
.hl-root .hl-sh-ico .material-symbols-outlined                { color: var(--hl-start-icon) !important; }
.hl-root .hl-show-more .material-symbols-outlined             { color: var(--hl-accent) !important; }

/* ── Hero ── */
.hl-hero {
  background: var(--hl-hero-gradient);
  padding: 75px 24px; text-align: center;
  border-bottom: 1px solid var(--hl-border-soft);
}
.hl-hero h1 { font-size: 1.8rem; font-weight: 700; color: var(--lp-text,#0f172a); margin: 0 0 6px; }
.hl-hero p  { font-size: 1rem; color: var(--lp-muted,#475569); margin: 0 0 22px; }
.hl-sbox {
  display: flex; max-width: 500px; margin: 0 auto;
  border-radius: var(--hl-radius); overflow: hidden;
  border: 1px solid var(--hl-border-soft); box-shadow: 0 2px 8px rgba(0,0,0,.1);
}
.hl-sbox input {
  flex: 1; border: none; padding: 12px 18px; font-size: 1rem;
  font-family: inherit; color: var(--lp-text); outline: none; background: #fff;
}
.hl-sbox input::placeholder { color: #bbb; }
.hl-sbox input:focus { outline: 3px solid var(--hl-accent); outline-offset: -3px; }
.hl-sbox-btn {
  background: var(--hl-accent); border: none; padding: 0 16px;
  cursor: pointer; display: flex; align-items: center;
}
.hl-sbox-btn:focus-visible { outline: 3px solid var(--hl-accent-strong); outline-offset: 2px; }

/* ── Category strip ── */
.hl-cat-strip {
  background: var(--hl-surface); border-bottom: 1px solid var(--hl-border-soft);
  display: flex; overflow-x: auto; padding: 0 24px; scrollbar-width: none;
  box-shadow: 0 1px 4px rgba(15,23,42,.06);
}
.hl-cat-strip::-webkit-scrollbar { display: none; }
.hl-ctab {
  display: flex; align-items: center; gap: 7px; padding: 12px 16px;
  font-size: .875rem; color: var(--lp-muted,#475569);
  border-bottom: 2.5px solid transparent; cursor: pointer;
  white-space: nowrap; user-select: none; background: none;
  border-top: none; border-left: none; border-right: none; font-family: inherit;
  transition: color .15s;
}
.hl-ctab .material-symbols-outlined { font-size: 18px; flex-shrink: 0; }
.hl-ctab.on  { color: var(--hl-accent); border-bottom-color: var(--hl-accent); font-weight: 700; }
.hl-ctab:hover:not(.on) { color: var(--hl-accent); }
.hl-ctab:focus-visible  { outline: 3px solid var(--hl-accent); outline-offset: -2px; }
.hl-ctab-n { font-size: .7rem; font-weight: 700; background: #1e3a5f; color: #fff; border-radius: 10px; padding: 1px 7px; }
.hl-ctab.on .hl-ctab-n { background: var(--hl-accent); }
.hl-ctab.hl-ctab-sh { color: #92400e; }
.hl-ctab.hl-ctab-sh.on { color: #92400e; border-bottom-color: #92400e; }
.hl-ctab.hl-ctab-sh .hl-ctab-n { background: #92400e; }
.hl-ctab.hl-ctab-sh.on .hl-ctab-n { background: #92400e; }

/* ── Page layout ── */
.hl-page-layout { display: grid; grid-template-columns: 215px 1fr; align-items: stretch; min-height: calc(100vh - 180px); }

/* ── Sidebar ── */
.hl-sidebar { background: transparent; border-right: 1px solid var(--hl-border-soft); }
.hl-sb-sec  { padding: 14px 0; border-bottom: 1px solid var(--hl-border-soft); }
.hl-sb-lbl  { font-size: .7rem; font-weight: 700; color: var(--hl-muted-label); text-transform: uppercase; letter-spacing: .06em; padding: 0 16px 8px; display: block; }
.hl-sbr {
  display: flex; align-items: center; gap: 9px; padding: 9px 16px;
  font-size: .875rem; color: var(--lp-muted,#475569); border-left: 3px solid transparent;
  cursor: pointer; background: none; border-top: none; border-right: none; border-bottom: none;
  width: 100%; text-align: left; font-family: inherit; transition: background .1s;
}
.hl-sbr:hover:not(.on) { background: var(--hl-accent-weak); }
.hl-sbr:focus-visible  { outline: 3px solid var(--hl-accent); outline-offset: -2px; }
.hl-sbr.on { color: var(--hl-accent); background: var(--hl-accent-weak); border-left-color: var(--hl-accent); font-weight: 700; }
.hl-sbr-n  { margin-left: auto; font-size: .7rem; font-weight: 700; background: #1e3a5f; color: #fff; border-radius: 10px; padding: 1px 7px; }
.hl-sbr.on .hl-sbr-n { background: var(--hl-accent); }
.hl-sb-cta { margin: 14px; background: var(--hl-accent-weak); border: 1px solid var(--lp-blue-mid,#aacdec); border-radius: var(--hl-radius-sm); padding: 14px; }
.hl-sb-cta p { font-size: .8rem; color: #000; line-height: 1.55; margin: 0 0 10px; }
.hl-sb-cta a { display: block; text-align: center; background: var(--hl-accent); color: #fff !important; font-size: .8rem; font-weight: 700; padding: 9px; border-radius: var(--hl-radius-sm); text-decoration: none; }
.hl-sb-cta a:hover { background: var(--hl-accent-strong); }
.hl-sb-cta a:focus-visible { outline: 3px solid var(--hl-accent); outline-offset: 2px; }

/* ── Main ── */
.hl-main { padding: 20px 24px; background: var(--hl-bg); }
.hl-main-hdr { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; flex-wrap: wrap; gap: 8px; }
.hl-count        { font-size: .875rem; color: var(--lp-muted,#475569); }
.hl-count strong { color: var(--lp-text,#0f172a); }
.hl-sort-pills   { display: flex; gap: 6px; }
.hl-spill {
  font-size: .8rem; padding: 5px 12px; border-radius: 20px;
  border: 1px solid var(--hl-border-soft); color: var(--lp-muted,#475569);
  background: var(--hl-surface); cursor: pointer; display: flex; align-items: center;
  gap: 5px; font-family: inherit; transition: all .12s;
}
.hl-spill .material-symbols-outlined { font-size: 16px; }
.hl-spill.on { background: var(--hl-accent-weak); border-color: var(--hl-accent); color: var(--hl-accent); font-weight: 700; }
.hl-spill:focus-visible { outline: 3px solid var(--hl-accent); outline-offset: 2px; }
.hl-sec-lbl { font-size: .7rem; font-weight: 700; color: var(--hl-muted-label); text-transform: uppercase; letter-spacing: .06em; margin-bottom: 10px; display: block; }

/* ── Start Here band ── */
.hl-sh-band { background: var(--hl-start-bg); border: 1px solid var(--hl-start-border); border-radius: var(--hl-radius); padding: 16px; margin-bottom: 20px; }
.hl-sh-hdr  { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
.hl-sh-ico .material-symbols-outlined { font-size: 20px; }
.hl-sh-title { font-size: .875rem; font-weight: 700; color: #92400e; text-transform: uppercase; letter-spacing: .06em; }
.hl-sh-desc  { font-size: .8rem; color: #78350f; margin-left: auto; }

/* ── Featured grid ── */
.hl-feat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 8px; }
.hl-fcard {
  background: var(--hl-surface); border: 1px solid var(--hl-border-soft);
  border-radius: var(--hl-radius); padding: 16px; cursor: pointer;
  transition: border-color .15s, box-shadow .15s; text-align: left; font-family: inherit; width: 100%;
}
.hl-fcard:hover         { border-color: var(--hl-accent); box-shadow: var(--hl-shadow); }
.hl-fcard:focus-visible { outline: 3px solid var(--hl-accent); outline-offset: 2px; }
.hl-sh-band .hl-fcard { border-color: #fcd34d; }
.hl-sh-band .hl-fcard:hover { border-color: var(--hl-start-border); box-shadow: 0 4px 12px rgba(245,158,11,.15); }
.hl-fc-top    { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
.hl-fc-ico    { width: 40px; height: 40px; border-radius: 9px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.hl-fc-badges { display: flex; flex-direction: column; gap: 4px; align-items: flex-end; }
.hl-fc-title  { font-size: .875rem; font-weight: 700; color: var(--lp-text,#0f172a); margin: 0 0 5px; line-height: 1.35; }
.hl-fc-desc   { font-size: .8rem; color: var(--lp-muted,#475569); line-height: 1.5; margin: 0; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }

/* ── Category groups ── */
.hl-grp { margin-bottom: 24px; }
.hl-grp-hdr {
  display: flex; align-items: center; gap: 10px; padding: 10px 0; margin-bottom: 8px;
  border-bottom: 2px solid var(--hl-border-soft); cursor: pointer;
  background: none; border-top: none; border-left: none; border-right: none;
  width: 100%; text-align: left; font-family: inherit;
}
.hl-grp-hdr:focus-visible { outline: 3px solid var(--hl-accent); outline-offset: 2px; }
.hl-grp-name    { font-size: 1rem; font-weight: 700; color: var(--lp-text,#0f172a); flex: 1; }
.hl-grp-count   { font-size: .7rem; font-weight: 700; background: #1e3a5f; color: #fff; border-radius: 10px; padding: 2px 8px; }
.hl-grp-chevron { font-size: 20px; transition: transform .2s; }
.hl-grp.collapsed .hl-grp-chevron { transform: rotate(-90deg); }
.hl-grp-body { display: flex; flex-direction: column; gap: 7px; }
.hl-grp.collapsed .hl-grp-body { display: none; }

/* ── List rows ── */
.hl-list-rows { display: flex; flex-direction: column; gap: 7px; }
.hl-lrow {
  display: flex; align-items: center; gap: 12px;
  background: var(--hl-surface); border: 1px solid var(--hl-border-soft);
  border-radius: var(--hl-radius); padding: 11px 14px; cursor: pointer;
  transition: border-color .15s; text-align: left; font-family: inherit; width: 100%;
  border-left-width: 4px;
}
.hl-lrow.hl-lrow-video    { border-left-color: var(--hl-row-border-video); }
.hl-lrow.hl-lrow-tutorial { border-left-color: var(--hl-row-border-tutorial); }
.hl-lrow.hl-lrow-faq      { border-left-color: var(--hl-row-border-faq); }
.hl-lrow:hover         { border-color: var(--hl-accent); border-left-color: var(--hl-accent); }
.hl-lrow:focus-visible { outline: 3px solid var(--hl-accent); outline-offset: 2px; }
.hl-lr-ico  { width: 32px; height: 32px; border-radius: 7px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.hl-lr-body { flex: 1; min-width: 0; }
.hl-lr-t    { font-size: .875rem; font-weight: 700; color: var(--lp-text,#0f172a); margin: 0 0 3px; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.hl-lr-m    { display: flex; align-items: center; gap: 7px; flex-wrap: wrap; }
.hl-lr-cat  { font-size: .7rem; color: var(--hl-muted-label); }

/* ── Show more ── */
.hl-show-more {
  display: flex; align-items: center; justify-content: center; gap: 6px;
  width: 100%; padding: 10px; margin-top: 8px;
  background: var(--hl-surface); border: 1px dashed var(--hl-border-soft);
  border-radius: var(--hl-radius-sm); cursor: pointer; font-family: inherit;
  font-size: .875rem; color: var(--hl-accent); font-weight: 600;
  transition: background .12s, border-color .12s;
}
.hl-show-more:hover         { background: var(--hl-accent-weak); border-color: var(--hl-accent); }
.hl-show-more:focus-visible { outline: 3px solid var(--hl-accent); outline-offset: 2px; }
.hl-show-more-global {
  display: flex; align-items: center; justify-content: center; gap: 6px;
  margin-top: 16px; padding: 12px 24px;
  background: var(--hl-surface); border: 1px solid var(--hl-border-soft);
  border-radius: var(--hl-radius); cursor: pointer; font-family: inherit;
  font-size: .875rem; color: var(--hl-accent); font-weight: 700;
  transition: background .12s, border-color .12s; width: 100%;
}
.hl-show-more-global:hover         { background: var(--hl-accent-weak); border-color: var(--hl-accent); }
.hl-show-more-global:focus-visible { outline: 3px solid var(--hl-accent); outline-offset: 2px; }

/* ── Badges ── */
.hl-badge { font-size: .7rem; font-weight: 700; padding: 2px 8px; border-radius: 10px; display: inline-block; }
.hl-bv { background: var(--hl-badge-video-bg);  color: var(--hl-badge-video-text); }
.hl-bt { background: var(--hl-badge-tut-bg);    color: var(--hl-badge-tut-text); }
.hl-bf { background: var(--hl-badge-faq-bg);    color: var(--hl-badge-faq-text); }
.hl-bn { background: var(--hl-badge-new-bg);    color: var(--hl-badge-new-text); }
.hl-ico-v { background: var(--hl-badge-video-bg); color: var(--hl-badge-video-text); }
.hl-ico-t { background: var(--hl-badge-tut-bg);   color: var(--hl-badge-tut-text); }
.hl-ico-f { background: var(--hl-badge-faq-bg);   color: var(--hl-badge-faq-text); }

/* ── Featured section header ── */
.hl-feat-hdr { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
.hl-feat-hdr-label { font-size: .875rem; font-weight: 700; color: var(--lp-text,#0f172a); }
.hl-feat-hdr-line  { flex: 1; height: 1px; background: var(--hl-border-soft); }

/* ── Loading ── */
.hl-loading { text-align: center; padding: 3rem; color: var(--lp-muted,#475569); font-size: .875rem; }
.hl-loading-msg { display: block; margin-bottom: 10px; min-height: 1.4em; transition: none; }
.hl-loading-dots { display: inline-flex; gap: 5px; }
.hl-loading-dots span { width: 8px; height: 8px; border-radius: 50%; background: var(--lp-blue-mid,#aacdec); animation: hl-bounce 1.2s infinite ease-in-out; }
.hl-loading-dots span:nth-child(2) { animation-delay: .2s; }
.hl-loading-dots span:nth-child(3) { animation-delay: .4s; }
@keyframes hl-bounce { 0%,80%,100%{transform:scale(.6);opacity:.5} 40%{transform:scale(1);opacity:1} }

/* ── Empty / error ── */
.hl-empty { text-align: center; padding: 3rem; color: var(--lp-muted,#475569); font-size: .875rem; background: var(--hl-surface); border-radius: var(--hl-radius); border: 1px solid var(--hl-border-soft); }
.hl-empty .material-symbols-outlined { font-size: 36px; display: block; margin: 0 auto 10px; }
.hl-empty-reset { margin-top: 12px; background: var(--hl-accent-weak); border: 1px solid var(--lp-blue-mid,#aacdec); color: var(--hl-accent); font-size: .8rem; font-weight: 700; padding: 8px 18px; border-radius: 20px; cursor: pointer; font-family: inherit; }
.hl-empty-reset:focus-visible { outline: 3px solid var(--hl-accent); outline-offset: 2px; }
.hl-err { text-align: center; padding: 2rem; color: #8a2020; font-size: .875rem; background: #fff3f3; border-radius: var(--hl-radius); border: 1px solid #f5c6c6; }

/* ── Detail page ── */
.hl-dpage     { display: none; }
.hl-dpage.on  { display: block; }
.hl-lpage.off { display: none; }

/* Breadcrumb — all segments same size, weight, color */
.hl-root .hl-dbc {
  background: transparent !important; padding: 16px 24px !important;
  display: flex !important; align-items: center !important;
  gap: 8px !important; flex-wrap: wrap !important;
  border-bottom: 1px solid var(--hl-border-soft);
  font-size: 1rem !important;
  font-weight: 600 !important;
  color: var(--lp-muted,#475569) !important;
}
.hl-root .hl-dbc a,
.hl-root .hl-dbc a:link,
.hl-root .hl-dbc a:visited {
  font-size: 1rem !important; font-weight: 600 !important;
  color: var(--hl-accent) !important; text-decoration: none !important;
  display: flex !important; align-items: center !important; gap: 4px !important;
}
.hl-root .hl-dbc a .hl-dbc-label  { text-decoration: underline !important; }
.hl-root .hl-dbc a:hover          { color: var(--hl-accent-strong) !important; }
.hl-root .hl-dbc a:focus-visible  { outline: 3px solid var(--hl-accent) !important; outline-offset: 3px !important; }
/* Category crumb — same accent style as Help Library link */
.hl-root .hl-dbc .hl-dbc-cat {
  font-size: 1rem !important; font-weight: 600 !important;
  color: var(--hl-accent) !important; text-decoration: underline !important;
}
.hl-root .hl-dbc .hl-dbc-cat:hover { color: var(--hl-accent-strong) !important; }
.hl-root .hl-dsep                  { font-size: 1rem !important; color: var(--hl-muted-label) !important; font-weight: 600 !important; }
.hl-root .hl-dbc > span:last-child { font-size: 1rem !important; color: var(--lp-muted,#475569) !important; font-weight: 600 !important; }

/* Detail hero */
.hl-dhero { background: transparent; padding: 20px 24px 16px; border-bottom: 1px solid var(--hl-border-soft); }
.hl-dhrow { display: flex; align-items: flex-start; gap: 16px; }
.hl-dhico { width: 52px; height: 52px; border-radius: 12px; background: var(--hl-accent-weak); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.hl-dhtxt h1    { font-size: 1.15rem; font-weight: 700; color: var(--lp-text,#0f172a); margin: 0 0 9px; line-height: 1.35; }
.hl-dhmeta      { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
.hl-dhmeta-item { font-size: .8rem; color: var(--lp-muted,#475569); display: flex; align-items: center; gap: 5px; }
.hl-dhmeta-item .material-symbols-outlined { color: var(--hl-muted-label) !important; }

/* Detail layout */
.hl-dlayout { display: grid; grid-template-columns: 1fr 240px; align-items: stretch; min-height: calc(100vh - 160px); background: var(--hl-bg); }
.hl-dmain { padding: 20px 24px; }

/* Video modal */
.hl-vid-modal { position: fixed; inset: 0; background: rgba(0,0,0,.75); z-index: 2000; display: none; align-items: center; justify-content: center; padding: 24px; }
.hl-vid-modal.is-open { display: flex; }
.hl-vid-modal-box {
  position: relative; width: 75vw; max-width: 1000px;
  background: #000; border-radius: 12px; overflow: hidden;
  box-shadow: 0 24px 64px rgba(0,0,0,.5);
}
.hl-vid-modal-ratio { position: relative; padding-bottom: 56.25%; height: 0; }
.hl-vid-modal-ratio iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
.hl-vid-modal-close {
  position: absolute; top: .625rem; right: .875rem;
  background: rgba(0,0,0,.6); color: #fff; border: none;
  font-size: 1.5rem; line-height: 1; padding: .25rem .625rem;
  border-radius: 6px; cursor: pointer; z-index: 10;
  min-width: 2.75rem; min-height: 2.75rem;
  display: inline-flex; align-items: center; justify-content: center;
  font-family: inherit;
}
.hl-vid-modal-close:hover { background: rgba(0,0,0,.9); }
.hl-vid-modal-close:focus-visible { outline: 3px solid #ffffff; outline-offset: 3px; }

/* Video fallback */
.hl-vid-fallback { display: flex; align-items: center; gap: 14px; background: var(--hl-accent-weak); border: 1px solid var(--lp-blue-mid,#aacdec); border-radius: var(--hl-radius); padding: 18px 22px; margin-bottom: 14px; text-decoration: none; transition: background .15s; }
.hl-vid-fallback:hover         { background: #b8d4f0; }
.hl-vid-fallback:focus-visible { outline: 3px solid var(--hl-accent); outline-offset: 2px; }
.hl-vid-fallback-ico { width: 48px; height: 48px; border-radius: 50%; background: var(--hl-accent); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.hl-vid-fallback strong { display: block; font-size: 1rem; font-weight: 700; color: var(--lp-text,#0f172a); margin-bottom: 2px; }
.hl-vid-fallback span   { font-size: .8rem; color: var(--lp-muted,#475569); }

/* Detail info card */
.hl-dcard { background: var(--hl-surface); border: 1px solid var(--hl-border-soft); border-radius: var(--hl-radius); padding: 16px; margin-bottom: 12px; }
.hl-dcard h2 { font-size: .875rem; font-weight: 700; color: var(--lp-text,#0f172a); margin: 0 0 12px; padding-bottom: 10px; border-bottom: 1px solid var(--hl-border-soft); }
.hl-dcard p  { font-size: .875rem; color: var(--lp-muted,#475569); line-height: 1.65; margin: 0 0 12px; }
.hl-dcard p:last-child { margin-bottom: 0; }
.hl-dmeta-row { display: flex; align-items: center; gap: 8px; font-size: .8rem; color: var(--hl-muted-label); margin-top: 4px; }

/* Detail sidebar */
.hl-dsb { padding: 20px 16px; border-left: 1px solid var(--hl-border-soft); display: flex; flex-direction: column; gap: 12px; background: transparent; align-self: stretch; }
.hl-dsbc { background: var(--hl-surface); border: 1px solid var(--hl-border-soft); border-radius: var(--hl-radius-sm); padding: 14px; }
.hl-dsbc h3 { font-size: .7rem; font-weight: 700; color: #000; text-transform: uppercase; letter-spacing: .06em; margin: 0 0 10px; }

/* Action buttons */
.hl-dact { display: flex; align-items: center; justify-content: center; gap: 8px; border-radius: var(--hl-radius-sm); padding: 9px 12px; margin-bottom: 7px; cursor: pointer; text-decoration: none; width: 100%; font-family: inherit; font-size: .875rem; font-weight: 600; transition: background .12s, border-color .12s; border: 1px solid var(--hl-border-soft); background: var(--hl-surface); color: var(--lp-text,#0f172a); box-sizing: border-box; }
.hl-dact:last-child    { margin-bottom: 0; }
.hl-dact:hover         { background: var(--hl-accent-weak); border-color: var(--hl-accent); color: var(--hl-accent); }
.hl-dact:focus-visible { outline: 3px solid var(--hl-accent); outline-offset: 2px; }

/* Related */
.hl-drel { display: flex; align-items: center; gap: 9px; padding: 8px 0; border-bottom: 1px solid var(--hl-border-soft); cursor: pointer; background: none; border-top: none; border-left: none; border-right: none; width: 100%; text-align: left; font-family: inherit; }
.hl-drel:last-child      { border-bottom: none; }
.hl-drel:hover .hl-drit { color: var(--hl-accent); }
.hl-drel:focus-visible   { outline: 3px solid var(--hl-accent); outline-offset: 2px; }
.hl-drii { width: 28px; height: 28px; border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.hl-drib { flex: 1; min-width: 0; }
.hl-drit { font-size: .8rem; font-weight: 700; color: var(--lp-text,#0f172a); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block; margin-bottom: 1px; transition: color .12s; }
.hl-dric { font-size: .7rem; color: var(--hl-muted-label); }

/* Consultation CTA */
.hl-dcta { background: var(--hl-accent-weak); border: 1px solid var(--lp-blue-mid,#aacdec); border-radius: var(--hl-radius-sm); padding: 14px; }
.hl-dcta h3 { font-size: .7rem; font-weight: 700; color: #000; text-transform: uppercase; letter-spacing: .06em; margin: 0 0 6px; }
.hl-dcta p  { font-size: .8rem; color: #000; line-height: 1.55; margin: 0 0 10px; }
.hl-dcta a  { display: block; text-align: center; background: var(--hl-accent); color: #fff !important; font-size: .8rem; font-weight: 700; padding: 9px; border-radius: var(--hl-radius-sm); text-decoration: none; }
.hl-dcta a:hover         { background: var(--hl-accent-strong); }
.hl-dcta a:focus-visible { outline: 3px solid var(--hl-accent); outline-offset: 2px; }

/* ── PDF modal ── */
.hl-pdf-modal { position: fixed; inset: 0; z-index: 2000; display: none; align-items: center; justify-content: center; padding: 24px; }
.hl-pdf-modal.is-open { display: flex; }
.hl-pdf-overlay { position: absolute; inset: 0; background: rgba(15,23,42,.65); }
.hl-pdf-dialog { position: relative; z-index: 1; width: 92vw; height: 90vh; max-width: 1100px; background: var(--hl-surface); border-radius: var(--hl-radius); border: 1px solid var(--hl-border-soft); box-shadow: 0 24px 64px rgba(0,0,0,.3); display: flex; flex-direction: column; overflow: hidden; }
.hl-pdf-header { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; background: var(--hl-navy-deep); border-bottom: 1px solid var(--hl-border-soft); flex-shrink: 0; }
.hl-pdf-title  { font-size: .9rem; font-weight: 700; color: #fff; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1; padding-right: 12px; }
.hl-pdf-close  { background: rgba(255,255,255,.15); border: 1px solid rgba(255,255,255,.3); color: #fff; border-radius: 6px; cursor: pointer; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; font-family: inherit; flex-shrink: 0; }
.hl-pdf-close:hover         { background: rgba(255,255,255,.25); }
.hl-pdf-close:focus-visible { outline: 3px solid #fff; outline-offset: 2px; }
.hl-pdf-body { flex: 1; background: #525659; display: flex; flex-direction: column; }
.hl-pdf-body object { width: 100%; height: 100%; border: none; display: block; flex: 1; }

.hl-sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }

/* ── Responsive ── */
@media (max-width:700px) {
  .hl-page-layout { grid-template-columns: 1fr; }
  .hl-sidebar { display: flex; flex-wrap: wrap; padding: 10px; gap: 6px; }
  .hl-sb-sec  { border: none; padding: 0; }
  .hl-sbr { border-radius: 20px; border: 1px solid var(--hl-border-soft) !important; padding: 5px 12px; flex: 0 0 auto; width: auto; }
  .hl-sb-cta    { width: 100%; }
  .hl-feat-grid { grid-template-columns: 1fr; }
  .hl-dlayout   { grid-template-columns: 1fr; }
  .hl-dsb       { border-left: none; border-top: 1px solid var(--hl-border-soft); }
  .hl-pdf-dialog{ width: 100%; height: 100%; border-radius: 0; }
}
@media (prefers-reduced-motion:reduce) {
  .hl-fcard,.hl-lrow,.hl-dact,.hl-show-more,.hl-loading-dots span { transition:none; animation:none; }
  .hl-grp-chevron { transition: none; }
}
</style>
